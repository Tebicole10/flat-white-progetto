# Flat White Progetto - Environment Variables

# Estos son ejemplos. Por ahora la app usa localStorage y no necesita variables,
# pero los dejamos para futuras expansiones (Firebase, Sentry, etc)

# Supabase (para sincronización en tiempo real en el futuro)
# VITE_SUPABASE_URL=https://your-project.supabase.co
# VITE_SUPABASE_ANON_KEY=your-anon-key

# Sentry (error tracking)
# VITE_SENTRY_DSN=https://your-sentry-dsn

# Google Maps (para autocompletar direcciones en el futuro)
# VITE_GOOGLE_MAPS_API_KEY=your-api-key
